.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code working files (ephemeral)
.claude/scheduled_tasks.lock
.claude/tasks.md
.claude/plan.md
.claude/scratch.md
.claude/cache/

# Spec workflow runtime artifacts (keep specs themselves)
.spec-workflow/.cache/
.spec-workflow/runtime/

# devenv / direnv
.devenv/
.devenv.flake.nix
.direnv/

# RC2 iter G: `crabscheme aot prog.scm` emits to `<basename>-aot/`
# by default. Ignore these tmp project directories so dev-loop
# usage doesn't pollute the workspace.
*-aot/
# ...but NOT the cs-aot crate itself (the `*-aot/` glob matches its
# `cs-aot/` directory name). Without this, new untracked files under
# the crate (e.g. a new test) would be silently un-added.
!crates/cs-aot/
!crates/cs-aot/**

# Real-world bench harness JSONL outputs.
bench/realworld/results/
